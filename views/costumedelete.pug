extends layout

block content
  h1= title

  h2 Are you sure you want to delete this?

  ul
    li Type: #{toShow.costume_type}
    li Size: #{toShow.size}
    li Cost: #{toShow.cost}

  form(id='deleteForm')
    button(type='submit') Delete

  script.
    document.getElementById('deleteForm').addEventListener('submit', async function(e) {
      e.preventDefault();
      const id = "#{toShow._id}";

      try {
        const resp = await fetch('/resource/costumes/' + id, {
          method: 'DELETE'
        });

        if (!resp.ok) {
          throw new Error("Delete failed");
        }

        alert("Delete successful");
        window.location.href = "/costumes";
      } catch (err) {
        alert("Delete failed: " + err);
      }
    });